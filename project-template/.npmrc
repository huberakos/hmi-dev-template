# HMI Projekt — npm biztonsági beállítások
# Supply chain attack megelőzés (Axios 2026.03.30 incidens tanulságai)

# Postinstall scriptek tiltása ismeretlen csomagoknál
ignore-scripts=true

# Audit automatikusan fut minden install-nál
audit=true

# Strict SSL (ne fogadjon el self-signed cert-et registry-hez)
strict-ssl=true

# Lockfile kötelező (nem engedi install nélkülöző lockfile-t)
package-lock=true

# Exact verziók mentése (nem ^, hanem pontos verzió)
save-exact=true
